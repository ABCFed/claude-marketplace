#!/bin/bash
# ABC Apifox CLI Wrapper

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# 检测 Python 解释器
if command -v python3 &> /dev/null; then
    PYTHON_CMD="python3"
elif command -v python &> /dev/null; then
    PYTHON_CMD="python"
else
    echo "错误: 找不到 Python 解释器"
    exit 1
fi

# 执行 Python 脚本
exec "$PYTHON_CMD" "$SCRIPT_DIR/apifox.py" "$@"
